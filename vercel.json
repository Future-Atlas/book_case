{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(googlebot|bingbot|yandexbot|duckduckbot|baiduspider|twitterbot|facebookexternalhit|facebot|linkedinbot|embedly|quora|slackbot).*"
        }
      ],
      "destination": "/api/seo?path=$1"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
