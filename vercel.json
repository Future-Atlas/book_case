{
    "version": 2,
    "public": true,
    "cleanUrls": true,
    "framework": null,
    "buildCommand": null,
    "outputDirectory": "build/web",
    "routes": [
        {
            "src": "/(.*)",
            "has": [
                {
                    "type": "query",
                    "key": "seo_preview",
                    "value": "1"
                }
            ],
            "dest": "/api/seo?path=$1"
        },
        {
            "src": "/",
            "has": [
                {
                    "type": "header",
                    "key": "user-agent",
                    "value": ".*([Gg]ooglebot|[Bb]ingbot|[Yy]andex[Bb]ot|[Dd]uck[Dd]uck[Bb]ot|[Bb]aiduspider|[Tt]witterbot|[Ff]acebookexternalhit|[Ff]acebot|[Ll]inkedinbot|[Ee]mbedly|[Qq]uora|[Ss]lackbot).*"
                }
            ],
            "dest": "/api/seo?path=/"
        },
        {
            "src": "/(genre/.*|book/.*|user/.*|profile/.*|privacy|terms)",
            "has": [
                {
                    "type": "header",
                    "key": "user-agent",
                    "value": ".*([Gg]ooglebot|[Bb]ingbot|[Yy]andex[Bb]ot|[Dd]uck[Dd]uck[Bb]ot|[Bb]aiduspider|[Tt]witterbot|[Ff]acebookexternalhit|[Ff]acebot|[Ll]inkedinbot|[Ee]mbedly|[Qq]uora|[Ss]lackbot).*"
                }
            ],
            "dest": "/api/seo?path=/$1"
        },
        {
            "src": "/sitemap.xml",
            "dest": "/api/sitemap"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/"
        }
    ]
}
